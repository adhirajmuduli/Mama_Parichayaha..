{
  "name": "bio-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "start:standalone": "npm run prepare:standalone && node scripts/start-standalone.mjs",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "unit": "vitest run",
    "coverage": "vitest run --coverage",
    "e2e": "npm run build && playwright test",
    "accessibility": "npm run e2e -- tests/e2e/accessibility.spec.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.4",
    "@react-three/fiber": "^9.1.2",
    "@react-three/postprocessing": "^3.0.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "motion": "12.42.0",
    "next": "^15.3.2",
    "next-themes": "^0.4.6",
    "postprocessing": "^6.37.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/eslintrc": "^3",
    "@gltf-transform/cli": "^4.4.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.1.5",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.176.0",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.17.0 <23",
    "npm": "11.4.2"
  },
  "packageManager": "npm@11.4.2"
}
